# ── SUPABASE ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...         # Never expose to browser

# ── INNGEST ──────────────────────────────────────────────────────────────────
INNGEST_EVENT_KEY=evt_...
INNGEST_SIGNING_KEY=signkey-...

# ── SITECORE ─────────────────────────────────────────────────────────────────
SITECORE_VERSION=xmcloud                  # xmcloud | xmxp
SITECORE_CM_URL=https://tenant.sitecorecloud.io
SITECORE_PARENT_PATH=/sitecore/content/Site/Personalization
SITECORE_LANGUAGE=en

# XM Cloud only
SITECORE_CLIENT_ID=your_client_id
SITECORE_CLIENT_SECRET=your_client_secret
SITECORE_AUDIENCE=https://api.sitecorecloud.io

# XM/XP only
SITECORE_API_KEY={your-api-key-guid}
SITECORE_DATABASE=master

# ── SALESFORCE ───────────────────────────────────────────────────────────────
SALESFORCE_LOGIN_URL=https://login.salesforce.com
SALESFORCE_USERNAME=api-user@yourcompany.com
SALESFORCE_PASSWORD=passwordPlusSalesforceSecurityToken

# ── IP ENRICHMENT ────────────────────────────────────────────────────────────
CLEARBIT_API_KEY=sk_...
SIXSENSE_API_KEY=...                       # Optional fallback

# ── CLAUDE API ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_MAX_TOKENS=1000

# ── PIPELINE ─────────────────────────────────────────────────────────────────
HOLDOUT_PERCENTAGE=20                      # 0-100, default 20
REDIS_URL=redis://localhost:6379           # Optional — in-memory fallback

# ── AE BRIEFS ────────────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
BOMBORA_API_KEY=...                        # Optional intent data
